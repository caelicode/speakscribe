# Deepgram API key (get one free at https://console.deepgram.com/signup)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Port for the WebSocket server (default: 3001)
PORT=3001

# LemonSqueezy API configuration (for license validation)
# Get your API key at https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here

# Optional: restrict to specific origins (comma-separated)
# Leave empty to allow all chrome-extension:// origins
ALLOWED_ORIGINS=
